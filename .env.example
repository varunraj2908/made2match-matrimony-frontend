# Copy to .env.local for local dev, and set these in your host's
# environment-variable settings (e.g. Vercel) for production.
# All NEXT_PUBLIC_* values are exposed to the browser — do not put secrets here.

# Backend API base URL. MUST be your production API in deploy (not localhost).
NEXT_PUBLIC_API_BASE_URL=http://13.61.8.91:8080/api/v1

# Public site origin (no trailing slash) — used for canonical/OG URLs, sitemap & robots.
NEXT_PUBLIC_SITE_URL=http://13.61.8.91:3000

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (HTML-tag method). Leave empty if using DNS.
NEXT_PUBLIC_GSC_VERIFICATION=

# Optional: Google Maps Embed API key for the LocationMap section.
# Leave empty to use the keyless fallback embed.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
